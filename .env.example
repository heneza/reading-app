# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# SERVER-ONLY secret (Project Settings -> API -> service_role key).
# Bypasses Row Level Security — required for username login (resolving a
# username to its account email). NEVER prefix this with NEXT_PUBLIC_ and
# never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET

# Optional: enables the reading assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: shows Cloudflare Turnstile CAPTCHA on auth forms.
# Put the matching secret key in Supabase Auth > Bot and Abuse Protection.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: sends welcome email after signup through Resend
RESEND_API_KEY=
EMAIL_FROM=Reading App <onboarding@example.com>
