# Copy this file to .env.local and fill in values from your Supabase project
# (Supabase dashboard -> Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: enables the reading assistant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: enables Cloudflare Turnstile CAPTCHA on signup
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: sends welcome email after signup through Resend
RESEND_API_KEY=
EMAIL_FROM=Reading App <onboarding@example.com>
